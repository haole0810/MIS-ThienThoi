<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- 1. Giao diện Danh sách (Tree View) -->
        <record id="view_yeu_cau_nhap_hang_tree" model="ir.ui.view">
            <field name="name">quan_ly_mua_hang.yeu_cau.tree</field>
            <field name="model">quan_ly_mua_hang.yeu_cau</field>
            <field name="arch" type="xml">
                <!-- Thêm decoration-warning cho trạng thái đã gửi mail -->
                <tree decoration-info="state == 'draft'" decoration-warning="state == 'sent'">
                    <field name="ma_yeu_cau"/>
                    <field name="ngay_lap"/>
                    <field name="state" widget="badge" 
                           decoration-info="state == 'draft'" 
                           decoration-warning="state == 'sent'"/>
                </tree>
            </field>
        </record>

        <!-- 2. Giao diện Chi tiết (Form View) -->
        <record id="view_yeu_cau_nhap_hang_form" model="ir.ui.view">
            <field name="name">quan_ly_mua_hang.yeu_cau.form</field>
            <field name="model">quan_ly_mua_hang.yeu_cau</field>
            <field name="arch" type="xml">
                <form string="Yêu cầu nhập hàng">
                    <header>
                        <button name="action_send_bulk_mail" 
                                string="Gửi Email hàng loạt cho NCC" 
                                type="object" 
                                class="oe_highlight" 
                                invisible="state != 'draft'"/>
                        
                        <button name="action_check_low_stock" 
                                string="Cập nhật hàng thiếu" 
                                type="object" 
                                invisible="state != 'draft'"/>

                        <field name="state" widget="statusbar" statusbar_visible="draft,sent"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="ma_yeu_cau" string="Mã phiếu yêu cầu"/>
                            <h1><field name="ma_yeu_cau"/></h1>
                        </div>
                        <group>
                            <field name="ngay_lap" readonly="state != 'draft'"/>
                        </group>

                        <notebook>
                            <page string="Danh sách sản phẩm thiếu hụt" name="lines">
                                <!-- Khuyên dùng: Khóa chỉnh sửa khi trạng thái khác draft -->
                                <field name="line_ids" readonly="state != 'draft'">
                                    <tree editable="bottom">
                                        <field name="san_pham_id"/>
                                        <field name="kho_id"/>
                                        <field name="so_luong_hien_tai" string="Tồn thực tế" readonly="1"/>
                                        <field name="muc_toi_thieu" string="Định mức" readonly="1"/>
                                        <field name="so_luong_can_nhap" string="Cần nhập"/>
                                        <field name="nha_cung_cap_id" options="{'no_create': True}" required="1"/>
                                        <field name="email_ncc" string="Email NCC"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <!-- 3. Server Action -->
        <record id="action_server_check_low_stock" model="ir.actions.server">
            <field name="name">Quét hàng thiếu ngay</field>
            <field name="model_id" ref="model_quan_ly_mua_hang_yeu_cau"/>
            <field name="state">code</field>
            <field name="code">
                action = model.action_check_low_stock()
            </field>
        </record>

        <!-- 4. Action mặc định -->
        <record id="action_yeu_cau_nhap_hang" model="ir.actions.act_window">
            <field name="name">Danh sách yêu cầu nhập hàng</field>
            <field name="res_model">quan_ly_mua_hang.yeu_cau</field>
            <field name="view_mode">tree,form</field>
        </record>

        <!-- 5. Menu -->
        <menuitem id="menu_quan_ly_mua_hang_root" name="Yêu cầu nhập hàng" sequence="25"/>
        <menuitem id="menu_yeu_cau_nhap_hang" name="Lịch sử yêu cầu" parent="menu_quan_ly_mua_hang_root" action="action_yeu_cau_nhap_hang" sequence="20"/>
        <menuitem id="menu_thuc_hien_quet_nhanh" name="Quét hàng thiếu" parent="menu_quan_ly_mua_hang_root" action="action_server_check_low_stock" sequence="10"/>
    </data>
</odoo>