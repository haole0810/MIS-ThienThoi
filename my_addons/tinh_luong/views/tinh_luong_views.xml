<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_tinh_luong_bang_luong_tree" model="ir.ui.view">
            <field name="name">tinh_luong.bang_luong.tree</field>
            <field name="model">tinh_luong.bang_luong</field>
            <field name="arch" type="xml">
                <tree string="Bảng lương">
                    <field name="name"/>
                    <field name="tu_ngay"/>
                    <field name="den_ngay"/>
                    <field name="so_nhan_vien"/>
                    <field name="tong_gio_cong" widget="float_time"/>
                    <field name="tong_gio_ot" widget="float_time"/>
                    <field name="tong_phat" sum="Tổng phạt"/>
                    <field name="tong_luong" sum="Tổng lương"/>
                    <field name="tong_thuc_nhan" sum="Tổng thực nhận" decoration-bf="1" decoration-success="1"/>
                    <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'done'" decoration-warning="state == 'computed'"/>
                </tree>
            </field>
        </record>

        <record id="view_tinh_luong_bang_luong_form" model="ir.ui.view">
            <field name="name">tinh_luong.bang_luong.form</field>
            <field name="model">tinh_luong.bang_luong</field>
            <field name="arch" type="xml">
                <form string="Bảng lương">
                    <header>
                        <button name="action_compute_salary" type="object" string="Tính lương" class="oe_highlight" invisible="state == 'done'"/>
                        <button name="action_done" type="object" string="Chốt bảng" invisible="state != 'computed'"/>
                        <button name="action_set_draft" type="object" string="Quay lại nháp" invisible="state == 'draft'"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,computed,done"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="tu_ngay"/>
                                <field name="den_ngay"/>
                            </group>
                            <group>
                                <field name="currency_id" invisible="1"/>
                                <field name="so_nhan_vien" readonly="1"/>
                                <field name="tong_gio_cong" readonly="1" widget="float_time"/>
                                <field name="tong_gio_ot" readonly="1" widget="float_time"/>
                            </group>
                        </group>
                        <group>
                            <group>
                                <field name="tong_phat" readonly="1"/>
                            </group>
                            <group>
                                <field name="tong_luong" readonly="1"/>
                                <field name="tong_thuc_nhan" readonly="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Chi tiết lương" name="line_tab">
                                <field name="line_ids" readonly="state == 'done'">
                                    <tree decoration-danger="tong_phat &gt; 0">
                                        <field name="nhan_vien_id"/>
                                        <field name="ma_nv"/>
                                        <field name="phong_ban_id"/>
                                        <field name="chuc_vu_id"/>
                                        <field name="gio_cong_thuc_te" widget="float_time"/>
                                        <field name="gio_nghi_phep_co_luong" widget="float_time"/>
                                        <field name="gio_nghi_khong_luong" widget="float_time"/>
                                        <field name="gio_ot" widget="float_time"/>
                                        <field name="phut_di_tre" string="Trễ (phút)"/>
                                        <field name="phut_ve_som" string="Sớm (phút)"/>

                                        <field name="tong_phat" string="Phạt"/>
                                        <field name="tong_luong" string="Tổng lương"/>
                                        <field name="thuc_nhan" string="Thực nhận" decoration-bf="1" decoration-success="1"/>
                                    </tree>
                                    <form string="Chi tiết lương">
                                        <sheet>
                                            <div class="oe_title mb-4">
                                                <h2 style="color: #017e84;">THÔNG TIN NHÂN VIÊN</h2>
                                            </div>
                                            <group>
                                                <group>
                                                    <field name="ma_nv" readonly="1"/>
                                                    <field name="nhan_vien_id" string="Tên nhân viên" readonly="1"/>
                                                </group>
                                                <group>
                                                    <field name="phong_ban_id" readonly="1"/>
                                                    <field name="chuc_vu_id" readonly="1"/>
                                                </group>
                                            </group>

                                            <div class="oe_title mt-4 mb-4">
                                                <h2 style="color: #017e84;">TỔNG QUAN LƯƠNG</h2>
                                            </div>
                                                <group string="Công &amp; Lương">
                                                    <field name="gio_cong_thuc_te" readonly="1" widget="float_time"/>
                                                    <field name="luong_cong_thuc_te" readonly="1"/>
                                                    <field name="gio_ot" readonly="1" widget="float_time"/>
                                                    <field name="tien_ot" readonly="1"/>
                                                </group>
                                                <group string="Khấu trừ (Phạt)">
                                                    <field name="phut_di_tre"/>
                                                    <field name="phut_ve_som"/>
                                                    <field name="tien_phat_di_tre"/>
                                                    <field name="tien_phat_ve_som"/>
                                                    <field name="tong_phat" style="font-weight: bold; color: #dc3545;"/>
                                                </group>

                                            <group class="mt-4">
                                                <group>
                                                    <field name="tong_luong" readonly="1" string="TỔNG THU NHẬP" style="font-size: 18px; font-weight: bold; color: #444;"/>
                                                    <field name="thuc_nhan" readonly="1" string="THỰC NHẬN" style="font-size: 24px; font-weight: bold; color: #28a745; border-top: 2px solid #28a745; padding-top: 10px;"/>
                                                </group>
                                            </group>

                                            <group class="mt-4">
                                                <field name="ghi_chu" readonly="1" placeholder="Không có ghi chú..."/>
                                            </group>
                                        </sheet>
                                    </form>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_tinh_luong_bang_luong" model="ir.actions.act_window">
            <field name="name">Bảng lương</field>
            <field name="res_model">tinh_luong.bang_luong</field>
            <field name="view_mode">tree,form</field>
        </record>

        <menuitem id="menu_tinh_luong_root" name="Tính lương" parent="nhan_su.menu_nhan_su_root" sequence="30"/>
        <menuitem id="menu_tinh_luong_bang_luong" name="Bảng lương" parent="menu_tinh_luong_root" action="action_tinh_luong_bang_luong" sequence="10"/>
    </data>
</odoo>
