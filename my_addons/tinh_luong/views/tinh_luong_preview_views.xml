<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tinh_luong_preview_form" model="ir.ui.view">
        <field name="name">tinh_luong.preview.form</field>
        <field name="model">tinh_luong.preview</field>
        <field name="arch" type="xml">
            <form string="Xem trước lương" create="false" edit="false">
                <sheet>
                    <group>
                        <group>
                            <field name="nhan_vien_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="tu_ngay" readonly="1"/>
                            <field name="den_ngay" readonly="1"/>
                        </group>
                    </group>

                    <group>
                        <group>
                            <field name="gio_cong_thuc_te" readonly="1" widget="float_time"/>
                            <field name="gio_ot" readonly="1" widget="float_time"/>
                        </group>
                    </group>

                    <group>
                        <group>
                            <field name="luong_gio" readonly="1"/>
                            <field name="luong_co_ban" readonly="1"/>
                        </group>
                        </group>

                    <group>
                        <group string="Khấu trừ (Phạt)">
                            <field name="tien_phat_di_tre"/>
                            <field name="tien_phat_ve_som"/>
                            <field name="tong_phat" style="font-weight: bold; color: #dc3545;"/>
                        </group>
                    </group>

                    <group class="mt-4">
                        <group>
                            <field name="tong_luong" readonly="1" string="TỔNG THU NHẬP" style="font-size: 18px; font-weight: bold; color: #444;"/>
                            <field name="thuc_nhan" readonly="1" string="THỰC NHẬN" style="font-size: 24px; font-weight: bold; color: #28a745; border-top: 2px solid #28a745; padding-top: 10px;"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button string="Đóng" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
