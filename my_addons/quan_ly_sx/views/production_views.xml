<odoo>
    <record id="view_phieu_san_xuat_tree" model="ir.ui.view">
        <field name="name">phieu.san.xuat.tree</field>
        <field name="model">phieu.san.xuat</field>
        <field name="arch" type="xml">
            <tree decoration-info="trang_thai == 'dang_lam'" decoration-success="trang_thai == 'xong'">
                <field name="name" string="Mã Phiếu"/>
                <field name="product_id" string="Thành phẩm"/>
                <field name="so_luong" string="Dự kiến"/>
                <field name="so_luong_thanh_pham_dat" string="Thực tế"/>
                <field name="nguoi_lam_ids" widget="many2many_tags" string="Người phụ trách"/>
                <field name="trang_thai" widget="badge" decoration-info="trang_thai == 'dang_lam'" decoration-success="trang_thai == 'xong'"/>
            </tree>
        </field>
    </record>

    <record id="view_phieu_san_xuat_form" model="ir.ui.view">
        <field name="name">phieu.san.xuat.form</field>
        <field name="model">phieu.san.xuat</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_start" string="Bắt đầu làm" type="object" class="oe_highlight" invisible="trang_thai != 'cho'"/>
                    <button name="action_done" string="Xác nhận hoàn thành" type="object" class="oe_highlight" invisible="trang_thai != 'dang_lam'"/>
                    <field name="trang_thai" widget="statusbar" statusbar_visible="cho,dang_lam,xong"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Kế hoạch sản xuất">
                            <field name="product_id" readonly="trang_thai != 'cho'"/>
                            <field name="so_luong" string="Số lượng dự kiến" readonly="trang_thai != 'cho'"/>
                            <field name="loai_phieu" readonly="trang_thai != 'cho'"/>
                            <field name="nguoi_lam_ids" widget="many2many_tags" readonly="trang_thai != 'cho'"/>
                        </group>
                        
                        <group string="Thực tế thực hiện" invisible="trang_thai == 'cho'">
                            <field name="so_luong_thanh_pham_dat" string="Sản lượng đạt"
                                   required="trang_thai == 'dang_lam'" 
                                   readonly="trang_thai == 'xong'"/>
                            <field name="so_luong_nguyen_lieu_dung" string="Nguyên liệu đã dùng"
                                   invisible="loai_phieu == 'sot'" 
                                   required="loai_phieu != 'sot' and trang_thai == 'dang_lam'" 
                                   readonly="trang_thai == 'xong'"/>
                            <field name="hao_hut" readonly="1" invisible="loai_phieu == 'sot'"/>
                        </group>
                    </group>

                    <group string="Thông tin hoàn thành" invisible="trang_thai != 'xong'">
                        <field name="log_hoan_thanh" string="Nhóm đã thực hiện"/>
                        <field name="ngay_tao"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_phieu_sot" model="ir.actions.act_window">
        <field name="name">Chế biến Sốt</field>
        <field name="res_model">phieu.san.xuat</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('loai_phieu', '=', 'sot')]</field>
    </record>

    <record id="action_phieu_tron" model="ir.actions.act_window">
        <field name="name">Xác nhận Trộn bánh</field>
        <field name="res_model">phieu.san.xuat</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('loai_phieu', '=', 'tron')]</field>
    </record>

    <record id="action_phieu_lua" model="ir.actions.act_window">
        <field name="name">Xác nhận Lựa bánh</field>
        <field name="res_model">phieu.san.xuat</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('loai_phieu', '=', 'lua')]</field>
    </record>

    <record id="action_phieu_san_xuat_all" model="ir.actions.act_window">
        <field name="name">Tất cả Lệnh sản xuất</field>
        <field name="res_model">phieu.san.xuat</field>
        <field name="view_mode">tree,form,graph</field>
    </record>

    <record id="view_thien_thoi_bom_form" model="ir.ui.view">
        <field name="name">thien.thoi.bom.form</field>
        <field name="model">thien.thoi.bom</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_validate" string="Xác nhận" type="object" class="oe_highlight" invisible="state == 'validated'"/>
                    <button name="action_set_to_draft" string="Sửa lại" type="object" invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="product_id" readonly="state == 'validated'"/>
                    </group>
                    <notebook>
                        <page string="Nguyên liệu (BOM Lines)">
                            <field name="line_ids" readonly="state == 'validated'">
                                <tree editable="bottom">
                                    <field name="product_id"/>
                                    <field name="quantity"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Quy trình thực hiện">
                            <field name="quy_trinh" placeholder="Nhập các bước chế biến tại đây..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    
    <record id="action_thien_thoi_bom" model="ir.actions.act_window">
        <field name="name">Công thức (BOM)</field>
        <field name="res_model">thien.thoi.bom</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_thien_thoi_root" name="Sản xuất Thiên Thời" action="action_phieu_san_xuat_all"/>
    <menuitem id="menu_phieu_sx_sub" name="Lệnh sản xuất" parent="menu_thien_thoi_root" sequence="10"/>
    
    <menuitem id="menu_phieu_sot" name="Chế biến Sốt" parent="menu_phieu_sx_sub" action="action_phieu_sot" 
              groups="quan_ly_sx.group_sx_worker_sot,quan_ly_sx.group_sx_manager" sequence="10"/>
    <menuitem id="menu_phieu_tron" name="Trộn bánh" parent="menu_phieu_sx_sub" action="action_phieu_tron" 
              groups="quan_ly_sx.group_sx_worker_tron,quan_ly_sx.group_sx_manager" sequence="20"/>
    <menuitem id="menu_phieu_lua" name="Lựa bánh" parent="menu_phieu_sx_sub" action="action_phieu_lua" 
              groups="quan_ly_sx.group_sx_worker_lua,quan_ly_sx.group_sx_manager" sequence="30"/>

    <menuitem id="menu_thien_thoi_config" name="Công thức Thiên Thời" parent="menu_thien_thoi_root" sequence="100"/>
    <menuitem id="menu_bom_config" name="Công thức (BOM)" parent="menu_thien_thoi_config" action="action_thien_thoi_bom" 
              groups="quan_ly_sx.group_sx_manager" sequence="10"/>
</odoo>