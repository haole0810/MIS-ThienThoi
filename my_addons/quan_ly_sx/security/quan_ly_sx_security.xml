<odoo>
    <record id="module_category_quan_ly_sx" model="ir.module.category">
        <field name="name">Sản xuất Thiên Thời</field>
        <field name="sequence">10</field>
    </record>

    <record id="group_sx_manager" model="res.groups">
        <field name="name">Sếp (Manager)</field>
        <field name="category_id" ref="module_category_quan_ly_sx"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_sx_worker_tron" model="res.groups">
        <field name="name">Nhân viên Ban Trộn</field>
        <field name="category_id" ref="module_category_quan_ly_sx"/>
    </record>

    <record id="group_sx_worker_lua" model="res.groups">
        <field name="name">Nhân viên Ban Lựa</field>
        <field name="category_id" ref="module_category_quan_ly_sx"/>
    </record>

    <record id="group_sx_worker_sot" model="res.groups">
        <field name="name">Nhân viên Ban Sốt</field>
        <field name="category_id" ref="module_category_quan_ly_sx"/>
    </record>

    <record id="rule_phieu_sx_worker_tron" model="ir.rule">
        <field name="name">Nhân viên Trộn: Chỉ xem phiếu Trộn</field>
        <field name="model_id" ref="model_phieu_san_xuat"/>
        <field name="domain_force">[('loai_phieu', '=', 'tron')]</field>
        <field name="groups" eval="[(4, ref('group_sx_worker_tron'))]"/>
    </record>

    <record id="rule_phieu_sx_worker_lua" model="ir.rule">
        <field name="name">Nhân viên Lựa: Chỉ xem phiếu Lựa</field>
        <field name="model_id" ref="model_phieu_san_xuat"/>
        <field name="domain_force">[('loai_phieu', '=', 'lua')]</field>
        <field name="groups" eval="[(4, ref('group_sx_worker_lua'))]"/>
    </record>

    <record id="rule_phieu_sx_worker_sot" model="ir.rule">
        <field name="name">Nhân viên Sốt: Chỉ xem phiếu Sốt</field>
        <field name="model_id" ref="model_phieu_san_xuat"/>
        <field name="domain_force">[('loai_phieu', '=', 'sot')]</field>
        <field name="groups" eval="[(4, ref('group_sx_worker_sot'))]"/>
    </record>

    <record id="rule_phieu_sx_manager_all" model="ir.rule">
        <field name="name">Sếp: Xem toàn bộ phiếu</field>
        <field name="model_id" ref="model_phieu_san_xuat"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_sx_manager'))]"/>
    </record>
</odoo>