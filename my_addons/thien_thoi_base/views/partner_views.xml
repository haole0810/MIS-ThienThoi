<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_thien_thoi_partner_tree" model="ir.ui.view">
        <field name="name">res.partner.tree.thienthoi</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <tree string="Danh sách đối tác">
                <field name="name" string="Tên đơn vị"/>
                <field name="partner_type" string="Phân loại"/>
                <field name="phone" string="Điện thoại"/>
                <field name="street" string="Địa chỉ"/>
            </tree>
        </field>
    </record>

    <record id="view_partner_form_thienthoi" model="ir.ui.view">
        <field name="name">res.partner.form.thienthoi</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='function']" position="after">
                <field name="partner_type" string="Phân loại Thiên Thời"/>
                <field name="comment_thien_thoi"/>
            </xpath>
        </field>
    </record>

    <record id="action_thien_thoi_partner" model="ir.actions.act_window">
        <field name="name">Đối tác Thiên Thời</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">tree,form</field>
    </record>
    <menuitem id="menu_thien_thoi_root" name="Hệ thống Thiên Thời" sequence="10"/>

    <menuitem id="menu_thien_thoi_partner" 
              name="Đối tác (NCC/Khách)" 
              parent="menu_thien_thoi_root" 
              action="action_thien_thoi_partner" 
              sequence="20"/>
</odoo>