<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_thien_thoi_product_tree" model="ir.ui.view">
        <field name="name">thien_thoi.product.tree</field>
        <field name="model">thien_thoi.product</field>
        <field name="arch" type="xml">
            <tree string="Danh mục hàng hóa">
                <field name="default_code" string="Mã SP"/>
                <field name="name" string="Tên sản phẩm"/>
                <field name="product_type" string="Loại hàng"/>
                <field name="uom_id" string="Đơn vị"/>
                <field name="list_price" string="Giá bán" sum="Total"/>
            </tree>
        </field>
    </record>

    <record id="view_thien_thoi_product_form" model="ir.ui.view">
        <field name="name">thien_thoi.product.form</field>
        <field name="model">thien_thoi.product</field>
        <field name="arch" type="xml">
            <form string="Thông tin sản phẩm">
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Tên sản phẩm"/>
                        <h1><field name="name" placeholder="Ví dụ: Bánh phôi sống"/></h1>
                    </div>
                    <group>
                        <group string="Thông tin định danh">
                            <field name="default_code"/>
                            <field name="product_type"/>
                            <field name="uom_id"/>
                        </group>
                        <group string="Thông tin tài chính">
                            <field name="list_price" widget="monetary"/>
                            <field name="standard_price" widget="monetary"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Mô tả kỹ thuật">
                            <field name="description" placeholder="Mô tả đặc điểm sản phẩm..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_thien_thoi_product" model="ir.actions.act_window">
        <field name="name">Sản phẩm Thiên Thời</field>
        <field name="res_model">thien_thoi.product</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_thien_thoi_product" 
              name="Sản phẩm (Bánh/Gia vị)" 
              parent="menu_thien_thoi_root" 
              action="action_thien_thoi_product" 
              sequence="15"/>
</odoo>