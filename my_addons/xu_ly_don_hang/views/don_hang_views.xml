<odoo>
    <record id="view_don_hang_form" model="ir.ui.view">
        <field name="name">don.hang.form</field>
        <field name="model">quan_ly_don_hang.don_hang</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" string="Xác nhận đơn" type="object" class="oe_highlight" invisible="trang_thai != 'nhap'"/>
                    <button name="action_pack" string="Đóng gói" type="object" invisible="trang_thai != 'xac_nhan'"/>
                    <button name="action_done" string="Xuất kho" type="object" class="oe_highlight" invisible="trang_thai != 'dong_goi'"/>
                    <button name="action_cancel" string="Hủy đơn" type="object" invisible="trang_thai in ['xuat_kho', 'huy']"/>
                    <field name="trang_thai" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="ma_don" readonly="1"/>
                        <field name="khach_hang_id" readonly="trang_thai != 'nhap'"/>
                        <field name="loai_khach_hang" widget="radio" options="{'horizontal': true}"/>
                        <field name="ngay_tao" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Danh sách sản phẩm">
                            <field name="chi_tiet_don_ids">
                                <tree editable="bottom">
                                    <field name="san_pham_id"/>
                                    <field name="so_luong"/>
                                    <field name="don_gia"/>
                                    <field name="thanh_tien"/>
                                </tree>
                            </field>
                            <group class="oe_subtotal_footer">
                                <field name="tong_tien" class="oe_subtotal_footer_separator"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_quan_ly_don_hang" model="ir.actions.act_window">
        <field name="name">Xử lý Đơn Hàng</field>
        <field name="res_model">quan_ly_don_hang.don_hang</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_don_hang_root" name="Quản lý Đơn Hàng" sequence="10"/>
    <menuitem id="menu_don_hang_sub" name="Đơn hàng" parent="menu_don_hang_root" action="action_quan_ly_don_hang"/>
</odoo>